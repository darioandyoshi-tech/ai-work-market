# AI Work Market Base Sepolia example env
# Copy to .env.base-sepolia.local and fill with TESTNET keys only.

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Buyer/funder key. Needs Base Sepolia ETH for gas and Base Sepolia USDC for escrow funding.
PRIVATE_KEY=0xREPLACE_WITH_TESTNET_BUYER_PRIVATE_KEY
DEPLOYER_ADDRESS=0xREPLACE_WITH_BUYER_ADDRESS

# Seller/agent key. Needs a little Base Sepolia ETH to submit proof.
SELLER_PRIVATE_KEY=0xREPLACE_WITH_TESTNET_SELLER_PRIVATE_KEY
SELLER_ADDRESS=0xREPLACE_WITH_SELLER_ADDRESS

# Live Base Sepolia deployment
ESCROW=0x489C36738F46e395b4cd26DDf0f85756686A2f07
USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# 0.01 USDC in 6-decimal raw units
E2E_USDC_AMOUNT=10000
