{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/manifesto", "destination": "/manifesto.html" },
    { "source": "/trust", "destination": "/trust.html" },
    { "source": "/founding-testers", "destination": "/founding-testers.html" },
    { "source": "/first-agents", "destination": "/first-agents.html" },
    { "source": "/integration-sprint", "destination": "/integration-sprint.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
